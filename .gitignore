# ─────────────────────────────────────────────────────────────
# Secrets & environment — never commit real credentials
# ─────────────────────────────────────────────────────────────
.env
.env.*
!.env.example
!.env.*.example

.envrc
.env.local
.env.*.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local

# Common secret file names
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
credentials.json
credentials/
secrets.json
secrets/
**/secrets/
token.json
token.txt
.auth/
service-account*.json
*-credentials.json
render.yaml.local

# ─────────────────────────────────────────────────────────────
# Cursor & other AI assistants — never commit
# ─────────────────────────────────────────────────────────────
.cursor/
**/.cursor/
.cursorrules
.cursorrules.*
.cursorignore
.cursor-*
.agents/
**/.agents/
.claude/
**/.claude/
CLAUDE.md
AGENTS.md
GEMINI.md
**/CLAUDE.md
**/AGENTS.md

