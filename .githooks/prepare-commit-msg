#!/bin/sh
# Strip Cursor co-author trailers injected by IDE/agent tooling.
commit_msg_file=$1
[ -f "$commit_msg_file" ] || exit 0

tmp="${commit_msg_file}.cursor-strip"
grep -viE '^[Cc]o-[Aa]uthored-[Bb]y:.*[Cc]ursor|cursoragent@cursor\.com' "$commit_msg_file" > "$tmp" || cp "$commit_msg_file" "$tmp"
mv "$tmp" "$commit_msg_file"
exit 0
