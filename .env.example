# ─────────────────────────────────────────────
# Copy this file to .env and fill in values
# NEVER commit .env to version control
# ─────────────────────────────────────────────

# ── KoboToolbox ──────────────────────────────
# Your API token: KoboToolbox → Account Settings → API Token
KOBO_API_TOKEN=your_kobo_api_token_here
# Asset UID from the KoboToolbox form URL:
# https://kf.kobotoolbox.org/#/forms/{ASSET_UID}/...
KOBO_ASSET_UID=your_form_asset_uid_here
# Staff Sentiment Survey asset UID (second instrument)
KOBO_SENTIMENT_ASSET_UID=your_sentiment_form_asset_uid_here

# KoboToolbox base URL (use humanitarian server if applicable)
# Default: https://kf.kobotoolbox.org
# Humanitarian: https://kobo.humanitarianresponse.info
KOBO_BASE_URL=https://kf.kobotoolbox.org

# ── Dashboard Auth ────────────────────────────
# Credentials for the dashboard login screen
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=your_strong_password_here

# JWT signing secret — use a long random string (min 32 chars)
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your_jwt_secret_key_here
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# ── Supabase ──────────────────────────────────
# Project URL — Supabase dashboard → Settings → API → Project URL
SUPABASE_URL=https://your-project-ref.supabase.co
# Service role key (never expose this to the frontend)
# Supabase dashboard → Settings → API → service_role key
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# ── Backend ───────────────────────────────────
BACKEND_PORT=8000
ENVIRONMENT=development

# ── Frontend (local dev; production: set on Vercel) ──
NEXT_PUBLIC_API_URL=http://localhost:8000
# Canonical URL for Open Graph / social previews (no trailing slash)
# Production example: https://readiness.your-domain.gov.lr
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Render API (production split deploy with Vercel frontend) ──
# Comma-separated browser origins allowed to call /auth/token from the client
# CORS_ALLOWED_ORIGINS=https://your-app.vercel.app,https://readiness.your-domain.gov.lr
